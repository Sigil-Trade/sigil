# ──────────────────────────────────────────────────────────────────
# AgentShield — Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
#
# NOT every variable is needed. Which ones you set depends on which
# part of the stack you're running. Read each section carefully.
# ──────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════
# SOLANA (shared across Actions server + MCP server)
# ══════════════════════════════════════════════════════════════════

# Solana JSON-RPC endpoint.
#
# WHO NEEDS THIS:
#   - The Actions server (apps/actions-server) uses this to build
#     transactions and look up on-chain vault status.
#   - The MCP server (packages/mcp) uses AGENTSHIELD_RPC_URL instead
#     (see below) — this var is NOT read by the MCP server.
#
# WHEN TO SET:
#   - Set this when deploying or running the Actions server locally.
#   - On Vercel, set it in the project's Environment Variables dashboard.
#
# WHEN TO SKIP:
#   - If you're only using the MCP server, SDK, or wrapper — skip this.
#     The MCP server has its own var (AGENTSHIELD_RPC_URL).
#   - If unset, the Actions server defaults to devnet:
#     https://api.devnet.solana.com
#
SOLANA_RPC_URL=https://api.devnet.solana.com

# AgentShield on-chain program ID.
#
# WHO NEEDS THIS:
#   - The Actions server, to derive PDA addresses for vaults/policies.
#
# WHEN TO SET:
#   - Only if you deployed your own instance of the program to a
#     different address. This is rare — most users use the canonical
#     deployment.
#
# WHEN TO SKIP:
#   - Almost always. If unset, the Actions server falls back to the
#     program ID exported by @agent-shield/sdk (the canonical deploy).
#   - The MCP server and SDK always use the canonical ID from the SDK
#     constant — this env var has no effect on them.
#
AGENTSHIELD_PROGRAM_ID=


# ══════════════════════════════════════════════════════════════════
# MCP SERVER (packages/mcp)
# ══════════════════════════════════════════════════════════════════
# These are ONLY read by the MCP server. If you're not running the
# MCP server (e.g. you're only using the SDK or Actions server),
# skip this entire section.
#
# NOTE: The MCP server also supports file-based config at
# ~/.agentshield/config.json (created by the shield_configure tool).
# If that file exists, it takes precedence over these env vars.
# These env vars exist as a fallback for backwards compatibility.

# Path to the OWNER wallet keypair JSON file.
#
# WHEN TO SET:
#   - Required when AGENTSHIELD_CUSTODY is unset (i.e. "local" mode).
#     This is the keypair that owns the vaults and signs policy changes.
#   - Example: ~/.config/solana/id.json
#
# WHEN TO SKIP:
#   - When using a TEE custody provider (AGENTSHIELD_CUSTODY=crossmint).
#     In that case, the custody provider manages the signing key and
#     this path is ignored.
#   - When ~/.agentshield/config.json exists — the config file's
#     wallet.path field is used instead.
#
AGENTSHIELD_WALLET_PATH=~/.config/solana/id.json

# Path to the AGENT keypair JSON file.
#
# This is NOT the owner wallet. This is a separate keypair for the
# AI agent that executes transactions within vault policy limits.
# The owner creates the vault + policy; the agent operates within it.
#
# WHEN TO SET:
#   - When the MCP server needs to sign transactions as the agent
#     (e.g. validate_and_authorize calls). This is the key the AI
#     agent uses to prove its identity to the vault.
#
# WHEN TO SKIP:
#   - During initial setup (vault creation, policy config) — those
#     are owner-signed operations that don't need the agent key.
#   - If your MCP server only does read operations (check-vault,
#     check-spending, etc.) — no signing needed.
#
AGENTSHIELD_AGENT_KEYPAIR_PATH=

# Solana RPC URL for the MCP server.
#
# WHEN TO SET:
#   - When running the MCP server against mainnet or a custom RPC.
#
# WHEN TO SKIP:
#   - If unset, defaults to devnet (https://api.devnet.solana.com).
#   - This is separate from SOLANA_RPC_URL (which is for the Actions
#     server). They CAN point to different endpoints if needed.
#
AGENTSHIELD_RPC_URL=https://api.devnet.solana.com

# Custody provider for the MCP server's signing wallet.
#
# Options: "crossmint" (TEE hardware enclave), "turnkey" (coming soon),
#          "privy" (coming soon), or leave unset for local keypair.
#
# WHEN TO SET:
#   - When you want the MCP server to use a TEE-backed wallet instead
#     of a local keypair file. This is Tier 2 (Shield + TEE) in the
#     three-tier onboarding model.
#
# WHEN TO SKIP:
#   - For local development or Tier 1 (Shield only). When unset,
#     the MCP server requires AGENTSHIELD_WALLET_PATH instead.
#
AGENTSHIELD_CUSTODY=


# ══════════════════════════════════════════════════════════════════
# CROSSMINT TEE CUSTODY
# ══════════════════════════════════════════════════════════════════
# These are needed in TWO places, for different reasons:
#
# 1. MCP SERVER: When AGENTSHIELD_CUSTODY=crossmint, the MCP server
#    uses these to create/load a Crossmint TEE wallet for signing.
#
# 2. ACTIONS SERVER: The provision-tee route uses CROSSMINT_API_KEY
#    server-side to provision new TEE wallets on behalf of users.
#    Users do NOT need their own Crossmint account — the API key
#    belongs to the server operator (set on Vercel dashboard).

# Crossmint API key for wallet provisioning and signing.
#
# WHEN TO SET:
#   - MCP server: Required when AGENTSHIELD_CUSTODY=crossmint.
#   - Actions server: Required on Vercel for the /provision-tee route.
#     Without it, that endpoint returns 503.
#
# WHEN TO SKIP:
#   - MCP server: When using local keypair custody (the default).
#   - Actions server: If you don't need TEE wallet provisioning.
#   - Never commit this value — it's a secret. On Vercel, set it in
#     the Environment Variables dashboard, not in .env.
#
CROSSMINT_API_KEY=

# Existing Crossmint wallet locator (e.g. "userId:agent-123").
#
# WHEN TO SET:
#   - When the MCP server should reuse an existing Crossmint wallet
#     instead of creating a new one. This is the locator returned by
#     a previous wallet creation call.
#
# WHEN TO SKIP:
#   - When you want the MCP server to create a new wallet on startup.
#   - When not using Crossmint custody at all.
#   - The Actions server does NOT use this — it always creates new
#     wallets via the provision-tee route.
#
CROSSMINT_WALLET_LOCATOR=


# ══════════════════════════════════════════════════════════════════
# ACTIONS SERVER (apps/actions-server)
# ══════════════════════════════════════════════════════════════════

# Port for the local Hono dev server.
#
# WHEN TO SET:
#   - When running `pnpm --filter actions-server dev` locally and
#     port 3001 is already in use.
#
# WHEN TO SKIP:
#   - On Vercel — Vercel ignores this and uses its own port.
#   - If 3001 is fine (the default).
#
PORT=3001


# ══════════════════════════════════════════════════════════════════
# ELIZAOS PLUGIN (plugins/elizaos)
# ══════════════════════════════════════════════════════════════════
# These are ONLY used by the ElizaOS plugin's provision action.
# If you're not running an ElizaOS agent with the AgentShield
# plugin, skip this entire section.
#
# NOTE: ElizaOS also supports runtime.getSetting() which takes
# precedence over env vars. You can set these in the ElizaOS
# character config instead of .env if you prefer.

# Platform URL for vault provisioning Blinks.
#
# WHEN TO SET:
#   - When running your own Actions server at a custom URL and
#     the ElizaOS agent needs to generate provision Blinks
#     pointing to it.
#
# WHEN TO SKIP:
#   - If unset, defaults to https://app.agentshield.dev.
#   - Most users should skip this unless self-hosting.
#
AGENT_SHIELD_PLATFORM_URL=https://agent-middleware.vercel.app

# Default policy template for new vault provisioning.
#
# Options: "conservative" (low caps, few protocols),
#          "moderate" (balanced), "aggressive" (high caps, many protocols)
#
# WHEN TO SET:
#   - When you want the ElizaOS agent to always provision vaults
#     with a specific risk profile without asking the user.
#
# WHEN TO SKIP:
#   - If unset, defaults to "conservative" (the safest option).
#
AGENT_SHIELD_DEFAULT_TEMPLATE=conservative

# Default daily spending cap in USD for new vaults.
#
# WHEN TO SET:
#   - When you want to override the template's default daily cap.
#     For example, set to 100 for a low-risk agent.
#
# WHEN TO SKIP:
#   - If unset, the template's built-in cap is used (varies by
#     template: conservative=$100, moderate=$500, aggressive=$2000).
#
AGENT_SHIELD_DAILY_CAP=


# ══════════════════════════════════════════════════════════════════
# CERTORA (optional — formal verification)
# ══════════════════════════════════════════════════════════════════

# Certora Solana Prover API key.
#
# WHEN TO SET:
#   - Only if you're running Certora formal verification on the
#     Anchor program. Get a free key at https://www.certora.com.
#
# WHEN TO SKIP:
#   - Always, unless you're actively doing formal verification.
#     This has zero impact on building, testing, or running any
#     part of the AgentShield stack.
#
CERTORAKEY=
