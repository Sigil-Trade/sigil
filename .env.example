# ══════════════════════════════════════════════════════════════════
#  Sigil — Environment Variables (repo contributors only)
# ══════════════════════════════════════════════════════════════════
#
#  This file is for people who clone the repo to develop or test.
#  If you installed a package via npm (e.g. `npx @usesigil/mcp`),
#  you do NOT need this file — see each package's README instead.
#
#  Copy to .env and fill in what you need. Most contributors only
#  need Section 1 (devnet tests) and optionally Section 2 (actions
#  server local dev).
#
#  NEVER commit .env files or secrets to git.
# ══════════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 1: DEVNET TESTS (tests/devnet-*.ts)
# │  Needed when: running `npx ts-mocha ... tests/devnet-*.ts`
# │  Not needed for: LiteSVM unit tests, TS package tests
# └─────────────────────────────────────────────────────────────────

# Solana RPC for devnet integration tests.
# Replace with your own RPC endpoint (e.g. Helius, Triton, QuickNode).
# Public devnet RPC (https://api.devnet.solana.com) will hit rate limits.
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Path to a funded devnet wallet keypair for paying test transactions.
ANCHOR_WALLET=~/.config/solana/id.json


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 2: ACTIONS SERVER LOCAL DEV (apps/actions-server)
# │  Needed when: running `pnpm --filter actions-server dev`
# │  Not needed for: testing, SDK work, plugin work
# └─────────────────────────────────────────────────────────────────

# Solana RPC endpoint for building transactions and querying chain.
# Must match the network where Sigil is deployed (currently devnet).
# Replace with your own RPC endpoint.
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Crossmint API key for the /provision-tee endpoint.
# Without it, that endpoint returns 503. Leave blank for local dev
# if you don't need TEE wallet provisioning.
CROSSMINT_API_KEY=

# Override the on-chain program ID (rare — only if you deployed your
# own instance). Defaults to the canonical devnet deployment.
SIGIL_PROGRAM_ID=

# Local dev server port (ignored on Vercel).
PORT=3001


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 3: MCP SERVER LOCAL DEV (packages/mcp)
# │  Needed when: developing the MCP server package itself
# │  Not needed for: using the MCP server (use `shield_configure`)
# └─────────────────────────────────────────────────────────────────

# Owner wallet keypair path (for local keypair mode).
# Skip when using TEE custody (SIGIL_CUSTODY=crossmint).
SIGIL_WALLET_PATH=~/.config/solana/id.json

# Agent keypair path (separate from owner — executes within policy).
# Only needed for agent-signed operations (validate_and_authorize).
SIGIL_AGENT_KEYPAIR_PATH=

# Solana RPC for the MCP server (separate from SOLANA_RPC_URL).
# Replace with your own RPC endpoint.
SIGIL_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Custody provider: "crossmint" or leave blank for local keypair.
SIGIL_CUSTODY=

# Crossmint wallet locator to reuse an existing wallet (e.g. "userId:agent-123").
# Leave blank to create a new wallet. Only used with SIGIL_CUSTODY=crossmint.
CROSSMINT_WALLET_LOCATOR=


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 4: FORMAL VERIFICATION (optional)
# │  Needed when: running Certora Solana Prover locally
# └─────────────────────────────────────────────────────────────────

# Certora API key — get one at https://www.certora.com
CERTORAKEY=


# ┌─────────────────────────────────────────────────────────────────
# │  REFERENCE: CI/CD Secrets (DO NOT put in .env)
# │  These live in GitHub repo Settings > Secrets > Actions
# │  and Vercel project > Settings > Environment Variables.
# │  Listed here only for documentation.
# └─────────────────────────────────────────────────────────────────
#
# GitHub Actions:
#   DEVNET_RPC_URL           — Helius devnet RPC (for devnet-test.yml)
#   DEVNET_WALLET_KEYPAIR    — JSON byte array of funded devnet keypair
#   CI_APP_PRIVATE_KEY       — GitHub App private key (README auto-commit)
#
# GitHub Variables:
#   CI_APP_ID                — GitHub App ID (README auto-commit)
#
# GitHub Environment "Certora":
#   CERTORAKEY               — Certora Solana Prover API key
#
# Vercel (agent-middleware.vercel.app):
#   SOLANA_RPC_URL           — Helius RPC (devnet until mainnet launch)
#   CROSSMINT_API_KEY        — Crossmint API key (mark as Sensitive)
