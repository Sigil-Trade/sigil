# ══════════════════════════════════════════════════════════════════
#  AgentShield — Environment Variables
# ══════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values you need.
#  NOT every variable is needed — it depends on which part of
#  the stack you're running. Each section labels WHERE to set it.
#
#  PLATFORMS:
#    .env        = Local development only (git-ignored)
#    Vercel      = Actions server deployment (agent-middleware.vercel.app)
#    GitHub      = CI/CD pipeline (Actions secrets/variables)
#
#  NEVER commit .env files or secrets to git.
# ══════════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 1: ACTIONS SERVER (apps/actions-server)
# │  Platform: .env (local) + Vercel (deployed)
# └─────────────────────────────────────────────────────────────────

# Solana RPC endpoint for building transactions and querying chain state.
# Used by: build-tx.ts, fund.ts, status.ts
# Default: https://api.devnet.solana.com
# NOTE: Must match the network where AgentShield is deployed (currently devnet).
#       Use a private RPC (e.g. Helius) to avoid public rate limits.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Crossmint API key for the /provision-tee route.
# Used by: provision-tee.ts (server-side TEE wallet creation)
# Without it, the /provision-tee endpoint returns 503.
# On Vercel: set in Environment Variables dashboard (mark as Sensitive).
CROSSMINT_API_KEY=

# Override the on-chain program ID (rare — most users skip this).
# Default: canonical program ID exported by @agent-shield/sdk.
# Only set if you deployed your own instance of the program.
AGENTSHIELD_PROGRAM_ID=

# Local dev server port (ignored on Vercel).
PORT=3001


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 2: MCP SERVER (packages/mcp)
# │  Platform: .env (local) or ~/.agentshield/config.json
# │  NOTE: config.json (created by shield_configure) takes precedence.
# └─────────────────────────────────────────────────────────────────

# Solana RPC URL for the MCP server.
# This is separate from SOLANA_RPC_URL (Actions server) — they can differ.
# Default: https://api.devnet.solana.com
AGENTSHIELD_RPC_URL=https://api.devnet.solana.com

# Path to the OWNER wallet keypair JSON file.
# Required when using local keypair custody (the default).
# Skip when using TEE custody (AGENTSHIELD_CUSTODY=crossmint).
AGENTSHIELD_WALLET_PATH=~/.config/solana/id.json

# Path to the AGENT keypair JSON file.
# This is NOT the owner — it's the AI agent's signing key that operates
# within vault policy limits (e.g. validate_and_authorize calls).
# Skip for read-only operations or during initial vault setup.
AGENTSHIELD_AGENT_KEYPAIR_PATH=

# TEE custody provider. Options: "crossmint" or leave blank for local keypair.
# When set, the MCP server uses a TEE-backed wallet instead of a local file.
AGENTSHIELD_CUSTODY=

# Crossmint credentials (only needed when AGENTSHIELD_CUSTODY=crossmint).
# CROSSMINT_API_KEY is shared with Section 1 — set it once.
# CROSSMINT_WALLET_LOCATOR reuses an existing wallet (e.g. "userId:agent-123").
# Leave blank to create a new wallet on startup.
CROSSMINT_WALLET_LOCATOR=


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 3: ELIZAOS PLUGIN (plugins/elizaos)
# │  Platform: .env or ElizaOS character config (runtime.getSetting)
# └─────────────────────────────────────────────────────────────────

# Platform URL for vault provisioning Blinks.
# Default: https://agent-middleware.vercel.app
# Only change if self-hosting the Actions server.
AGENT_SHIELD_PLATFORM_URL=https://agent-middleware.vercel.app

# Default policy template for new vaults: "conservative", "moderate", "aggressive"
# Default: conservative
AGENT_SHIELD_DEFAULT_TEMPLATE=conservative

# Override the template's default daily spending cap (in USD).
# Leave blank to use the template default ($100/$500/$2000).
AGENT_SHIELD_DAILY_CAP=


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 4: LOCAL DEVNET TESTING (tests/devnet-*.ts)
# │  Platform: .env (local development only)
# │  Skip this entire section if only running LiteSVM unit tests.
# └─────────────────────────────────────────────────────────────────

# Solana RPC for devnet integration tests.
# Use a private RPC (e.g. Helius devnet) to avoid rate limits.
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Path to a funded devnet wallet keypair for paying test transactions.
ANCHOR_WALLET=~/.config/solana/id.json


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 5: GITHUB ACTIONS (CI/CD only)
# │  Platform: GitHub repo Settings > Secrets and variables > Actions
# │  DO NOT put these in .env — they are GitHub-only.
# │
# │  Repository Secrets:
# │    DEVNET_RPC_URL          Helius devnet RPC URL (for devnet-test.yml)
# │    DEVNET_WALLET_KEYPAIR   JSON byte array of funded devnet keypair
# │    CI_APP_PRIVATE_KEY      GitHub App private key (for README auto-commit)
# │
# │  Repository Variables:
# │    CI_APP_ID               GitHub App ID (for README auto-commit)
# │
# │  Environment Secrets (scoped to "Certora" environment):
# │    CERTORAKEY              Certora Solana Prover API key
# │
# │  HOW TO CREATE THE DEVNET KEYPAIR:
# │    solana-keygen new --no-bip39-passphrase -o devnet-ci.json
# │    solana airdrop 2 devnet-ci.json --url devnet
# │    cat devnet-ci.json  # paste contents into DEVNET_WALLET_KEYPAIR secret
# └─────────────────────────────────────────────────────────────────


# ┌─────────────────────────────────────────────────────────────────
# │  SECTION 6: VERCEL (deployed Actions server)
# │  Platform: Vercel project > Settings > Environment Variables
# │  DO NOT put these in .env — they are Vercel-only.
# │
# │  Production:
# │    SOLANA_RPC_URL         Helius RPC (devnet until mainnet launch)
# │    CROSSMINT_API_KEY      Crossmint production API key (Sensitive)
# │
# │  Preview / Development:
# │    SOLANA_RPC_URL         Helius devnet RPC
# │    CROSSMINT_API_KEY      Crossmint staging API key
# └─────────────────────────────────────────────────────────────────
