{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @agent-shield/sdk build && mkdir -p public && echo '{}' > public/.keep",
  "rewrites": [
    { "source": "/.well-known/actions.json", "destination": "/api/discovery" }
  ],
  "headers": [
    {
      "source": "/api/actions/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, OPTIONS" },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, Content-Encoding, Accept-Encoding"
        }
      ]
    }
  ]
}
