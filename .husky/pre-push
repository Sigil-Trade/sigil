# Tier 1 pre-push gate — fast-fail checks before reaching the wire.
# Target budget: <10s. Anything slower belongs in CI, not here.
#
# Bypass for intentional WIP pushes: `git push --no-verify`.
# Don't bypass just because the check annoys you; fix the underlying issue.

set -e

# Skip in CI. The dedicated `Lint`, `Rust Lint`, and `verify-test-counts` jobs
# already run these same checks, and the changesets release action fires two
# parallel `git push` invocations (commit + per-package tag) that then race on
# `~/.rustup/downloads/` when cargo fmt triggers a clippy component fetch —
# one push wins, the other fails with a rename ENOENT, and a tag gets dropped
# (this is how @usesigil/plugins@3.0.0 never reached the remote on 2026-04-15).
# The gate's purpose is a developer-workstation tripwire; skipping it in CI
# removes a false-positive failure mode without losing any real coverage.
[ -n "$CI" ] && exit 0

echo "→ [pre-push] test-count drift + untracked location sentinel..."
pnpm count:check

echo "→ [pre-push] prettier lint..."
pnpm lint

echo "→ [pre-push] cargo fmt..."
cargo fmt --check --manifest-path programs/sigil/Cargo.toml

echo "✓ [pre-push] all gates passed"
