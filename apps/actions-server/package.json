{
  "name": "@agent-shield/actions-server",
  "version": "0.1.2",
  "description": "Solana Actions server for AgentShield vault provisioning via Blinks",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "mocha --require ts-node/register 'tests/*.test.ts' --timeout 30000",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "hono": "^4.11.10",
    "@hono/node-server": "^1.13.0",
    "@solana/actions": "^1.6.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@agent-shield/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vercel": "^39.0.0"
  },
  "license": "Apache-2.0"
}
