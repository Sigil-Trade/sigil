{
  "name": "@usesigil/kit",
  "version": "0.2.2",
  "type": "module",
  "author": "Kaleb Rupe (https://x.com/MightieMags)",
  "homepage": "https://github.com/Sigil-Trade/sigil#readme",
  "bugs": {
    "url": "https://github.com/Sigil-Trade/sigil/issues",
    "email": "https://t.me/MightyMags"
  },
  "description": "Kit-native TypeScript SDK for Sigil — zero web3.js dependency, ESM-only",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    },
    "./testing/devnet": {
      "import": "./dist/testing/devnet.js",
      "types": "./dist/testing/devnet.d.ts"
    },
    "./x402": {
      "import": "./dist/x402/index.js",
      "types": "./dist/x402/index.d.ts"
    },
    "./dashboard": {
      "import": "./dist/dashboard/index.js",
      "types": "./dist/dashboard/index.d.ts"
    },
    "./constraints": {
      "import": "./dist/constraints/index.js",
      "types": "./dist/constraints/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "codama": "node codama.mjs",
    "codama:flash": "node codama.mjs --protocol=flash-trade",
    "codama:kamino": "node codama.mjs --protocol=kamino",
    "codama:all": "node codama.mjs --all",
    "pretest": "tsc -p tsconfig.test.json --noEmit",
    "test": "mocha --require tsx 'tests/*.test.ts' 'tests/core/*.test.ts' 'tests/dashboard/*.test.ts' --timeout 30000",
    "test:devnet": "mocha --require tsx tests/devnet/**/*.test.ts --timeout 300000",
    "test:experimental": "mocha --require tsx tests/experimental/**/*.test.ts --timeout 30000",
    "check:examples": "tsc -p tsconfig.examples.json"
  },
  "dependencies": {
    "@solana-program/compute-budget": "^0.15.0"
  },
  "peerDependencies": {
    "@solana/kit": "^6.2.0"
  },
  "optionalDependencies": {
    "cbor-x": "^1.6.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "1.3.9",
    "@codama/renderers-js": "2.0.3",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.6",
    "chai": "^6.2.2",
    "codama": "1.5.1",
    "fast-check": "^3.23.2",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0"
  },
  "keywords": [
    "solana",
    "ai-agent",
    "solana-kit",
    "defi",
    "security",
    "spending-limits",
    "policy-engine",
    "esm"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sigil-Trade/sigil",
    "directory": "sdk/kit"
  }
}
