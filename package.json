{
  "name": "sigil",
  "version": "0.1.1",
  "description": "On-chain guardrails for AI agents on Solana",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r run build && changeset publish",
    "security:xray": "docker run --rm --volume \"$(pwd):/workspace\" ghcr.io/sec3-product/x-ray:latest /workspace/programs/sigil",
    "security:fuzz": "cd trident-tests && trident fuzz run fuzz_0",
    "security:verify": "source .certora-venv/bin/activate && certoraSolanaProver certora/conf/sigil.conf",
    "surfpool:start": "surfpool start --network devnet --slot-time 100",
    "surfpool:start:ci": "surfpool start --network devnet --slot-time 100 --ci",
    "test:surfpool": "npx ts-mocha -p ./tsconfig.json -t 300000 tests/surfpool-integration.ts",
    "test:onchain": "npx ts-mocha -p ./tsconfig.json -t 300000 tests/sigil.ts tests/jupiter-integration.ts tests/flash-trade-integration.ts tests/security-exploits.ts",
    "update-readme": "node scripts/update-test-counts.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "flash-sdk": "^15.12.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@codama/nodes-from-anchor": "^1.4.0",
    "@codama/renderers-js": "^2.1.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "litesvm": "^0.6.0",
    "mocha": "^11.7.5",
    "prettier": "^3.2.5",
    "sinon": "^21.0.3",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.5",
    "@solana/web3.js": "^1.98.4",
    "bn.js": ">=5.2.3",
    "ajv": ">=8.18.0",
    "minimatch@^3.0.0": ">=3.1.4",
    "express-rate-limit": ">=8.2.2",
    "nanoid": ">=3.3.5",
    "tar": ">=7.5.11",
    "undici": ">=6.24.0",
    "picomatch": ">=2.3.2",
    "brace-expansion": ">=2.0.3",
    "serialize-javascript": ">=7.0.5",
    "langsmith": ">=0.4.6",
    "jsondiffpatch": ">=0.7.2",
    "ai": ">=5.0.52",
    "yaml": ">=2.8.3"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "path-to-regexp": ">=8.4.0",
      "langsmith": ">=0.4.6",
      "jsondiffpatch": ">=0.7.2",
      "nanoid": ">=3.3.5",
      "ai": ">=5.0.52"
    }
  },
  "workspaces": [
    "sdk/*",
    "sdk/custody/*",
    "packages/*",
    "apps/*"
  ]
}
