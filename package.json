{
  "name": "agent-shield",
  "version": "0.1.1",
  "description": "On-chain guardrails for AI agents on Solana",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r run build && changeset publish",
    "security:xray": "docker run --rm --volume \"$(pwd):/workspace\" ghcr.io/sec3-product/x-ray:latest /workspace/programs/agent-shield",
    "security:fuzz": "cd trident-tests && trident fuzz run fuzz_0",
    "security:verify": "source .certora-venv/bin/activate && certoraSolanaProver certora/conf/agent_shield.conf",
    "update-readme": "node scripts/update-test-counts.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "flash-sdk": "^15.1.2"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.5",
      "@solana/web3.js": "^1.98.4",
      "bn.js": ">=5.2.3",
      "ajv": ">=8.18.0"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@types/bn.js": "^5.1.5",
    "@types/bs58": "^4.0.4",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^4.4.1",
    "litesvm": "^0.5.0",
    "mocha": "^10.3.0",
    "prettier": "^3.2.5",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3"
  }
}
