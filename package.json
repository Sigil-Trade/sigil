{
  "name": "phalnx",
  "version": "0.1.1",
  "description": "On-chain guardrails for AI agents on Solana",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r run build && changeset publish",
    "security:xray": "docker run --rm --volume \"$(pwd):/workspace\" ghcr.io/sec3-product/x-ray:latest /workspace/programs/phalnx",
    "security:fuzz": "cd trident-tests && trident fuzz run fuzz_0",
    "security:verify": "source .certora-venv/bin/activate && certoraSolanaProver certora/conf/phalnx.conf",
    "surfpool:start": "surfpool start --network devnet --slot-time 100",
    "surfpool:start:ci": "surfpool start --network devnet --slot-time 100 --ci",
    "test:surfpool": "npx ts-mocha -p ./tsconfig.json -t 300000 tests/surfpool-integration.ts",
    "test:onchain": "npx ts-mocha -p ./tsconfig.json -t 300000 tests/phalnx.ts tests/jupiter-integration.ts tests/flash-trade-integration.ts tests/security-exploits.ts",
    "update-readme": "node scripts/update-test-counts.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "flash-sdk": "^15.1.4"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.5",
      "@solana/web3.js": "^1.98.4",
      "bn.js": ">=5.2.3",
      "ajv": ">=8.18.0"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^6.2.2",
    "litesvm": "^0.5.0",
    "mocha": "^11.7.5",
    "prettier": "^3.2.5",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.3.3"
  }
}
