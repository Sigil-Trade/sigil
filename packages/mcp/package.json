  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "peerDependencies": {
    "@phalnx/custody-crossmint": ">=0.1.4",
    "@phalnx/sdk": ">=0.5.4",
    "@coral-xyz/anchor": ">=0.32.1",
    "@solana/spl-token": ">=0.4.0",
    "@solana/web3.js": ">=1.95.0",
    "zod": "^3.25.0 || ^4.0.0",
    "@sqds/multisig": ">=2.1.0"
  },
  "peerDependenciesMeta": {
