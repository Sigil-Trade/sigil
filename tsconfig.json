{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@usesigil/kit/testing": ["./sdk/kit/dist/testing/index.d.ts"],
      "@usesigil/kit/testing/errors": [
        "./sdk/kit/dist/testing/errors/index.d.ts"
      ],
      "@usesigil/kit/post-assertions": [
        "./sdk/kit/dist/post-assertions/index.d.ts"
      ]
    }
  }
}
